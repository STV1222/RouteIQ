# ============================================================
# RouteIQ Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ----------------------------------------------------------
# LLM Provider API Keys
#
# Option A — OpenRouter (recommended): one key for all models.
# Set USE_OPENROUTER=true and fill in OPENROUTER_API_KEY.
# No other provider keys are needed.
#
# Option B — Direct APIs: set USE_OPENROUTER=false and provide
# individual keys for each provider you want to use.
# ----------------------------------------------------------

# --- Option A: OpenRouter ---
USE_OPENROUTER=true
OPENROUTER_API_KEY=sk-or-...

# --- Option B: Direct provider keys (used when USE_OPENROUTER=false) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ----------------------------------------------------------
# Infrastructure
# ----------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=300

# DynamoDB table names
DYNAMODB_TABLE_USAGE=routeiq_usage
DYNAMODB_TABLE_KEYS=routeiq_api_keys

# AWS region (used for DynamoDB + Lambda)
AWS_REGION=us-east-1

# For local dev with DynamoDB Local (docker-compose):
# DYNAMODB_ENDPOINT_URL=http://localhost:8000

# ----------------------------------------------------------
# App Behaviour
# ----------------------------------------------------------
# Default model used for savings comparison when client doesn't specify one
DEFAULT_MODEL=gpt-5.4

# Environment: development | staging | production
ROUTEIQ_ENV=development

# Max fallback attempts before returning error
MAX_FALLBACK_ATTEMPTS=3

# ----------------------------------------------------------
# Dev Flags (set to "true" to enable)
# ----------------------------------------------------------
# Skip API key validation (useful for local testing without DynamoDB)
SKIP_AUTH=false

# Skip Redis cache entirely (forces live LLM calls every time)
SKIP_CACHE=false
